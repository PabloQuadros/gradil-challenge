<UserControl x:Class="GradilChallenge.Presentation.Views.QuoteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,16,0">

            <TextBlock Text="Comprimento total desejado (metros):" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox Text="{Binding DesiredLengthText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

            <TextBlock Text="Altura da cerca:" FontWeight="Bold" Margin="0,0,0,4"/>
            <ComboBox ItemsSource="{Binding AvailableHeights}" DisplayMemberPath="Name"
                      SelectedItem="{Binding SelectedHeight}" Margin="0,0,0,12"/>

            <TextBlock Text="Cor da cerca:" FontWeight="Bold" Margin="0,0,0,4"/>
            <ComboBox ItemsSource="{Binding AvailableColors}" DisplayMemberPath="Name"
                      SelectedItem="{Binding SelectedColor}" Margin="0,0,0,16"/>

            <CheckBox Content="Cerca fechada"
                IsChecked="{Binding IsClosed}" Margin="0,0,0,16"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="Calcular Cerca" Command="{Binding CalculateCommand}"
                        Padding="12,6" Margin="0,0,8,0"/>
                <Button Content="Confirmar Pedido" Command="{Binding ConfirmCommand}"
                        Padding="12,6"/>
            </StackPanel>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap"
                       Margin="0,0,0,12"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <StackPanel Margin="0,0,0,12"
                        Visibility="{Binding HasQuote, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock FontWeight="Bold">
                    <Run Text="Comprimento vendido: "/>
                    <Run Text="{Binding Quote.SoldLength, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Foreground="DarkOrange"
                           Visibility="{Binding Quote.HasDifference, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Run Text="Diferença em relação ao solicitado: "/>
                    <Run Text="{Binding Quote.DifferenceInMeters, Mode=OneWay, StringFormat={}{0:0.00} m}"/>
                </TextBlock>
            </StackPanel>

            <TextBlock Text="Lista de Componentes:" FontWeight="Bold" Margin="0,0,0,4"/>
            <DataGrid ItemsSource="{Binding ComponentsTable}" AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="None"
                      MinHeight="150">
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding Name, Mode=OneWay}" Width="*"/>
                    <DataGridTextColumn Binding="{Binding Quantity, Mode=OneWay}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>

        </StackPanel>

        <Grid Grid.Column="1" xmlns:drawing="clr-namespace:GradilChallenge.Presentation.Models.Drawing">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Esboço da Cerca:" FontWeight="Bold" Margin="0,0,0,4"/>

            <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1"
            Height="280" ClipToBounds="True">
                <Grid>
                    <Grid Visibility="{Binding HasQuote, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="220"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#6eb9ff"/>
                        <Border Grid.Row="1" Background="#8B7355"/>
                        <Border Grid.Row="2" Background="White"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding FenceDrawing}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>

                        <ItemsControl.Resources>
                            <DataTemplate DataType="{x:Type drawing:RectangleShape}">
                                <Rectangle Width="{Binding Width}" Height="{Binding Height}"
                                   Fill="{Binding Fill}" Stroke="{Binding Stroke}"
                                   StrokeThickness="1"/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type drawing:LineShape}">
                                <Line X1="0" Y1="0" X2="{Binding LengthX}" Y2="{Binding LengthY}"
                              Stroke="{Binding Stroke}" StrokeThickness="{Binding Thickness}"/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type drawing:TextShape}">
                                <TextBlock Text="{Binding Text}" FontSize="{Binding FontSize}"
                                   Foreground="{Binding Foreground}"/>
                            </DataTemplate>
                        </ItemsControl.Resources>
                    </ItemsControl>

                    <TextBlock Text="Calcule uma cerca para ver o esboço."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextWrapping="Wrap" TextAlignment="Center" Margin="20"
                       Foreground="#606060"
                       Visibility="{Binding HasQuote, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
