<Application x:Class="GradilChallenge.Presentation.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GradilChallenge.Presentation.ViewModels"
             xmlns:views="clr-namespace:GradilChallenge.Presentation.Views"
             xmlns:converters="clr-namespace:GradilChallenge.Presentation.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>

            <DataTemplate DataType="{x:Type vm:QuoteViewModel}">
                <views:QuoteView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:OrderHistoryViewModel}">
                <views:OrderHistoryView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>